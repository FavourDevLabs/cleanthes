<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="@color/cleanthes_black">

	<!-- Logo mark -->
	<ImageView
		android:id="@+id/iv_splash_logo"
		android:layout_width="72dp"
		android:layout_height="72dp"
		android:src="@drawable/ic_cleanthes_logo"
		android:contentDescription="@string/cd_cleanthes_logo"
		app:tint="@color/cleanthes_accent"
		app:layout_constraintTop_toTopOf="parent"
		app:layout_constraintBottom_toTopOf="@id/tv_app_name"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent"
		app:layout_constraintVertical_chainStyle="packed"
		app:layout_constraintVertical_bias="0.36" />

	<!-- App name -->
	<TextView
		android:id="@+id/tv_app_name"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="18dp"
		android:text="CLEANTHES"
		android:textColor="@color/cleanthes_text_primary"
		android:textSize="26sp"
		android:letterSpacing="0.35"
		android:fontFamily="sans-serif-light"
		app:layout_constraintTop_toBottomOf="@id/iv_splash_logo"
		app:layout_constraintBottom_toTopOf="@id/v_divider"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent" />

	<!-- Accent rule -->
	<View
		android:id="@+id/v_divider"
		android:layout_width="40dp"
		android:layout_height="1dp"
		android:layout_marginTop="20dp"
		android:background="@color/cleanthes_accent"
		app:layout_constraintTop_toBottomOf="@id/tv_app_name"
		app:layout_constraintBottom_toTopOf="@id/tv_quote"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent" />

	<!-- Stoic quote -->
	<TextView
		android:id="@+id/tv_quote"
		android:layout_width="0dp"
		android:layout_height="wrap_content"
		android:layout_marginTop="20dp"
		android:layout_marginStart="48dp"
		android:layout_marginEnd="48dp"
		android:text="The willing are led by fate;\nthe unwilling are dragged."
		android:textColor="@color/cleanthes_text_secondary"
		android:textSize="14sp"
		android:fontFamily="sans-serif-light"
		android:textStyle="italic"
		android:gravity="center"
		android:lineSpacingMultiplier="1.4"
		app:layout_constraintTop_toBottomOf="@id/v_divider"
		app:layout_constraintBottom_toTopOf="@id/tv_attribution"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent" />

	<!-- Attribution -->
	<TextView
		android:id="@+id/tv_attribution"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginTop="10dp"
		android:text="— Cleanthes of Assos"
		android:textColor="@color/cleanthes_accent_dim"
		android:textSize="11sp"
		android:letterSpacing="0.08"
		android:fontFamily="sans-serif"
		app:layout_constraintTop_toBottomOf="@id/tv_quote"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent" />

	<!-- Studio brand — bottom anchor -->
	<TextView
		android:id="@+id/tv_brand"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content"
		android:layout_marginBottom="28dp"
		android:text="@string/app_brand"
		android:textColor="@color/cleanthes_border"
		android:textSize="9sp"
		android:letterSpacing="0.25"
		android:fontFamily="sans-serif"
		app:layout_constraintBottom_toBottomOf="parent"
		app:layout_constraintStart_toStartOf="parent"
		app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
